        <promptName>Draft_IT_Troubleshooting</promptName>
        <promptTemplateName>Draft_IT_Troubleshooting</promptTemplateName>
        <promptTitle>Draft IT Troubleshooting</promptTitle>
    </prompts>
    <tools>
        <apiDefinition>
            <apiIdentifier>aa:apex-CreateCaseAction</apiIdentifier>
            <apiSource>API_CATALOG</apiSource>
            <operation>CreateCaseAction</operation>
        </apiDefinition>
        <descriptionOverride>Creates a new Salesforce support Case from a subject line and returns its record Id and Case Number.</descriptionOverride>
        <toolName>CreateCaseActionapex_CreateCaseAction</toolName>
        <toolTitle>CreateCaseAction</toolTitle>
    </tools>
